					"userId": {
						"type": "string",
						"description": "Owner user id."
					},
					"name": {
						"type": "string",
						"maxLength": 80
					},
					"description": {
						"type": "string",
						"maxLength": 240
					},
					"color": {
						"type": "string",
						"pattern": "^#[0-9a-fA-F]{6}$",
						"description": "Hex color in `#rrggbb` format."
					},
					"isDefault": {
						"type": "boolean"
					},
					"createdAt": {
						"type": "string",
						"format": "date-time"
					}
				}
			},
			"ProfilesListResponse": {
				"type": "object",
				"required": [
					"profiles"
				],
				"properties": {
					"profiles": {
						"type": "array",
						"items": {
							"$ref": "#/components/schemas/Profile"
						}
					}
				}
			},
			"ProfileResponse": {
				"type": "object",
				"required": [
					"profile"
				],
				"properties": {
					"profile": {
						"$ref": "#/components/schemas/Profile"
					}
				}
			},
