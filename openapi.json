						"type": "string"
					},
					"profileId": {
						"$ref": "#/components/schemas/AccountProfileSummary"
					},
					"username": {
						"type": "string"
					},
					"displayName": {
						"type": "string"
					},
					"profileUrl": {
						"type": "string",
						"format": "uri"
					},
					"avatarUrl": {
						"type": "string",
