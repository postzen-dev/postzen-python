						"maxLength": 80
					},
					"description": {
						"type": "string",
						"maxLength": 240
					},
					"color": {
						"type": "string",
						"pattern": "^#[0-9a-fA-F]{6}$",
						"default": "#ffeda0"
					}
				}
			},
			"ProfileUpdateRequest": {
				"type": "object",
