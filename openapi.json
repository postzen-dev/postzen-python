												"accountId": {
													"_id": "j97kp4mw2xnv6r1t8c3zq5bs9fh0yg4d",
													"platform": "twitter",
													"username": "acme",
													"displayName": "Acme",
													"isActive": true
												},
												"status": "published",
												"platformPostUrl": "https://x.com/acme/status/1934567890123456789"
