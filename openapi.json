					"limit": {
						"type": "integer",
						"minimum": 1,
						"maximum": 100
					},
					"total": {
						"type": "integer",
						"minimum": 0
					},
					"totalPages": {
						"type": "integer",
						"minimum": 0
					}
				}
			},
			"AccountsListResponse": {
				"type": "object",
				"required": [
					"accounts"
				],
				"properties": {
					"accounts": {
						"type": "array",
						"items": {
							"$ref": "#/components/schemas/Account"
						}
					},
					"pagination": {
						"$ref": "#/components/schemas/Pagination"
					}
				}
			},
			"ConnectStartResponse": {
				"type": "object",
				"required": [
					"authUrl",
					"state"
